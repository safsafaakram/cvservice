import json
import logging
import os
import time

import pika


logging.basicConfig(level=os.getenv("LOG_LEVEL", "INFO"), format="%(message)s")
logger = logging.getLogger("notification_service")

RABBITMQ_HOST = os.getenv("RABBITMQ_HOST", "localhost")
RABBITMQ_PORT = int(os.getenv("RABBITMQ_PORT", "5672"))
RABBITMQ_USER = os.getenv("RABBITMQ_USER", "guest")
RABBITMQ_PASSWORD = os.getenv("RABBITMQ_PASSWORD", "guest")
CV_RESULTS_QUEUE = os.getenv(
    "RABBITMQ_CV_RESULTS_QUEUE",
    os.getenv("CV_RESULTS_QUEUE", "cv_results_queue"),
)


def log_event(event, **payload):
    logger.info(json.dumps({"event": event, **payload}))


def connection_parameters():
    credentials = pika.PlainCredentials(RABBITMQ_USER, RABBITMQ_PASSWORD)
    return pika.ConnectionParameters(
        host=RABBITMQ_HOST,
        port=RABBITMQ_PORT,
        credentials=credentials,
        heartbeat=600,
        blocked_connection_timeout=300,
        connection_attempts=3,
        retry_delay=2,
    )


def callback(channel, method, properties, body):
    try:
        message = json.loads(body.decode("utf-8"))
        cv_id = message["cv_id"]
        job_id = message["job_id"]
        score = float(message["score"])

        log_event(
            "cv_scored_notification",
            cv_id=cv_id,
            job_id=job_id,
            score=score,
        )
        channel.basic_ack(delivery_tag=method.delivery_tag)
    except (json.JSONDecodeError, KeyError, TypeError, ValueError) as exc:
        log_event(
            "notification_invalid_message",
            error=str(exc),
            body=body.decode("utf-8", errors="replace"),
        )
        channel.basic_nack(delivery_tag=method.delivery_tag, requeue=False)
    except Exception as exc:
        log_event("notification_processing_failed", error=str(exc))
        channel.basic_nack(delivery_tag=method.delivery_tag, requeue=True)


def start_worker():
    while True:
        connection = None
        try:
            connection = pika.BlockingConnection(connection_parameters())
            channel = connection.channel()
            channel.queue_declare(queue=CV_RESULTS_QUEUE, durable=True)
            channel.basic_qos(prefetch_count=1)

            log_event("notification_worker_listening", queue=CV_RESULTS_QUEUE)
            channel.basic_consume(
                queue=CV_RESULTS_QUEUE,
                on_message_callback=callback,
                auto_ack=False,
            )
            channel.start_consuming()
        except KeyboardInterrupt:
            log_event("notification_worker_stopping")
            if connection and connection.is_open:
                connection.close()
            break
        except (pika.exceptions.AMQPError, OSError) as exc:
            log_event("notification_rabbitmq_connection_failed", error=str(exc), retry_in_seconds=5)
            time.sleep(5)
        finally:
            if connection and connection.is_open:
                connection.close()


if __name__ == "__main__":
    start_worker()
